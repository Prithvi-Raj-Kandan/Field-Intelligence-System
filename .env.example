# Environment template — copy manually to .env.local (never commit .env.local)
# The agent/tooling only edits this file (.env.example), not your local secrets file.
#
#   cp .env.example .env.local    # macOS/Linux
#   copy .env.example .env.local  # Windows

# Database (matches docker-compose.yml — host port 5433 avoids local Postgres on 5432)
DATABASE_URL=postgresql://fieldintel:fieldintel@localhost:5433/fieldintel

# File storage (local dev)
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# Google Gemini API — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# CORS (Vite dev server)
CORS_ORIGINS=http://localhost:5173

# Frontend (used at build time)
# VITE_API_URL=http://localhost:8000
