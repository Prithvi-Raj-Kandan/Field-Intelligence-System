# Environment template — copy manually to .env.local (never commit .env.local)
#
#   cp .env.example .env.local    # macOS/Linux
#   copy .env.example .env.local  # Windows

# Database (matches docker-compose.yml — host port 5433)
DATABASE_URL=postgresql://fieldintel:fieldintel@localhost:5433/fieldintel

# File storage
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
# Production S3 (STORAGE_BACKEND=s3)
S3_BUCKET=
AWS_REGION=ap-south-1
# Optional — for local S3 testing without IAM role; omit on App Runner (uses instance role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Gemini API keys — use TWO keys to split transcription vs debrief quotas
# https://aistudio.google.com/apikey
GEMINI_TRANSCRIBE_API_KEY=
GEMINI_DEBRIEF_API_KEY=
# Legacy single-key fallback (optional if both above are set)
GEMINI_API_KEY=
GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash
GEMINI_DEBRIEF_MODEL=gemini-2.5-flash

# Auth — use strong secrets in production (AWS Secrets Manager)
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=480
ENVIRONMENT=development
COOKIE_SECURE=false
ALLOW_MANAGER_REGISTRATION=false

# Demo seed passwords (dev only — set in .env.local, never commit)
DEMO_WORKER_PASSWORD=FieldIntel-Worker-2026!
DEMO_MANAGER_PASSWORD=FieldIntel-Manager-2026!

# CORS (production: your HTTPS frontend origin only)
CORS_ORIGINS=http://localhost:5173

# Frontend build (production API URL — must be HTTPS)
# VITE_API_URL=https://api.yourdomain.com
