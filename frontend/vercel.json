{
  "rewrites": [
    {
      "source": "/auth/:path*",
      "destination": "https://field-intel-app-9etyb.ondigitalocean.app/auth/:path*"
    },
    {
      "source": "/visits",
      "destination": "https://field-intel-app-9etyb.ondigitalocean.app/visits"
    },
    {
      "source": "/visits/:path*",
      "destination": "https://field-intel-app-9etyb.ondigitalocean.app/visits/:path*"
    },
    {
      "source": "/insights/:path*",
      "destination": "https://field-intel-app-9etyb.ondigitalocean.app/insights/:path*"
    },
    {
      "source": "/workers",
      "destination": "https://field-intel-app-9etyb.ondigitalocean.app/workers"
    },
    {
      "source": "/workers/:path*",
      "destination": "https://field-intel-app-9etyb.ondigitalocean.app/workers/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://field-intel-app-9etyb.ondigitalocean.app/media/:path*"
    },
    {
      "source": "/health",
      "destination": "https://field-intel-app-9etyb.ondigitalocean.app/health"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
